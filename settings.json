{
  "cli_default_open_behavior": "new_window",
  "icon_theme": "Zed (Default)",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "diff_view_style": "split",
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
  },
  "vertical_scroll_margin": 8,
  "file_scan_exclusions": [
    "**/.git",
    "**/node_modules",
    "**/__pycache__",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/.pytest_cache",
    "**/dist",
    "**/build",
  ],
  "confirm_quit": true,
  "ui_font_size": 14.0,
  "buffer_font_size": 14.0,
  "soft_wrap": "editor_width",
  "autosave": "on_focus_change",
  "auto_signature_help": false,
  "show_signature_help_after_edits": false,
  "preferred_line_length": 100,
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": true,
    "toggle_on_modifiers_press": {
      "function": true,
    },
  },
  "buffer_font_features": { "calt": false },
  "use_autoclose": false,
  "terminal": {
    "font_size": 14.0,
    "dock": "bottom",
    "detect_venv": {
      "on": {
        "directories": [".venv", "venv", "local/.venv"],
        "activate_script": "default",
      },
    },
  },
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
  },
  "tabs": { "file_icons": true },

  "max_tabs": 5,
  "colorize_brackets": true,
  "indent_guides": {
    "background_coloring": "disabled",
  },
  "theme": {
    "mode": "light",
    "light": "One Light",
    "dark": "One Dark",
  },
  "jupyter": {
    "enabled": true,
    "kernel_selections": {
      "python": "conda-env",
      "typescript": "deno",
      "javascript": "deno",
      "r": "ark",
    },
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
  },
  "agent": {
    "dock": "left",
    "profiles": {
      "se": {
        "name": "SE",
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "restore_file_from_disk": true,
          "save_file": true,
          "open": true,
          "grep": true,
          "spawn_agent": true,
          "terminal": true,
          "thinking": true,
          "update_plan": true,
          "search_web": true,
        },

        "enable_all_context_servers": true,
        "context_servers": {},
      },
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "openai",
      "model": "gpt-5.5",
    },
    "favorite_models": [],
    "model_parameters": [],
    "default_profile": "write",
    "tool_permissions": {
      "tools": {
        "search_web": {
          "default": "allow",
        },
        "edit_file": {
          "default": "allow",
          "always_deny": [
            { "pattern": "\\.env($|\\.)" },
            { "pattern": "secrets?/" },
            { "pattern": "\\.(pem|key|p12|pfx)$" },
            { "pattern": "\\.ssh/" },
          ],
          "always_allow": [{ "pattern": ".*" }],
        },
        "delete_path": {
          "default": "confirm",
        },
        "move_path": {
          "default": "confirm",
        },
        "save_file": {
          "default": "allow",
        },
        "restore_file_from_disk": {
          "default": "confirm",
        },
        "copy_path": {
          "default": "allow",
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^yarn\\s+tsc(\\s|$)"
            },
            {
              "pattern": "^yarn\\s+lint(\\s|$)"
            },
            {
              "pattern": "^yarn\\s+validate\\-parallel(\\s|$)"
            },
            {
              "pattern": "^yarn\\s+eslint(\\s|$)"
            }
          ],
          "always_deny": [
            // python -c allows arbitrary inline code execution with no audit trail
            { "pattern": "^python3?\\s+-c\\b" },
          ],
        },
        // fetch: allow only known documentation/registry domains, confirm everything else
        "fetch": {
          "default": "confirm",
          "always_allow": [
            {
              "pattern": "https?://(www\\.)?developer\\.mozilla\\.org",
            },
            {
              "pattern": "https?://(www\\.)?stackoverflow\\.com",
            },
            {
              "pattern": "https?://(www\\.)?zed\\.dev",
            },
            {
              "pattern": "https?://(www\\.)?zod\\.dev",
            },
            {
              "pattern": "https?://(www\\.)?devdocs\\.io",
            },
            {
              "pattern": "https?://docs\\.rs",
            },
            {
              "pattern": "https?://crates\\.io",
            },
            {
              "pattern": "https?://(www\\.)?rust-lang\\.org",
            },
            {
              "pattern": "https?://docs\\.python\\.org",
            },
            {
              "pattern": "https?://pypi\\.org",
            },
            {
              "pattern": "https?://docs\\.pydantic\\.dev",
            },
            {
              "pattern": "https?://fastapi\\.tiangolo\\.com",
            },
            {
              "pattern": "https?://(www\\.)?djangoproject\\.com",
            },
            {
              "pattern": "https?://flask\\.palletsprojects\\.com",
            },
            {
              "pattern": "https?://(www\\.)?sqlalchemy\\.org",
            },
            {
              "pattern": "https?://(www\\.)?npmjs\\.com",
            },
            {
              "pattern": "https?://(www\\.)?nodejs\\.org",
            },
            {
              "pattern": "https?://www\\.typescriptlang\\.org",
            },
            {
              "pattern": "https?://(www\\.)?jsr\\.io",
            },
            {
              "pattern": "https?://deno\\.land",
            },
            {
              "pattern": "https?://(www\\.)?bun\\.sh",
            },
            {
              "pattern": "https?://(www\\.)?react\\.dev",
            },
            {
              "pattern": "https?://(www\\.)?nextjs\\.org",
            },
            {
              "pattern": "https?://(www\\.)?vitejs\\.dev",
            },
            {
              "pattern": "https?://(www\\.)?vitest\\.dev",
            },
            {
              "pattern": "https?://(www\\.)?astro\\.build",
            },
            {
              "pattern": "https?://(www\\.)?svelte\\.dev",
            },
            {
              "pattern": "https?://(www\\.)?nuxt\\.com",
            },
            {
              "pattern": "https?://(www\\.)?remix\\.run",
            },
            {
              "pattern": "https?://tailwindcss\\.com",
            },
            {
              "pattern": "https?://(www\\.)?prisma\\.io",
            },
            {
              "pattern": "https?://trpc\\.io",
            },
            {
              "pattern": "https?://(www\\.)?graphql\\.org",
            },
            {
              "pattern": "https?://(www\\.)?eslint\\.org",
            },
            {
              "pattern": "https?://(www\\.)?prettier\\.io",
            },
            {
              "pattern": "https?://jestjs\\.io",
            },
            {
              "pattern": "https?://testing-library\\.com",
            },
            {
              "pattern": "https?://(www\\.)?postgresql\\.org",
            },
            {
              "pattern": "https?://(www\\.)?redis\\.io",
            },
            {
              "pattern": "https?://(www\\.)?mongodb\\.com",
            },
            {
              "pattern": "https?://docs\\.docker\\.com",
            },
            {
              "pattern": "https?://kubernetes\\.io",
            },
            {
              "pattern": "https?://learn\\.microsoft\\.com",
            },
            {
              "pattern": "https?://docs\\.aws\\.amazon\\.com",
            },
            {
              "pattern": "https?://aws\\.amazon\\.com/documentation",
            },
            {
              "pattern": "https?://repost\\.aws",
            },
            {
              "pattern": "https?://docs\\.anthropic\\.com",
            },
            {
              "pattern": "https?://platform\\.openai\\.com",
            },
            {
              "pattern": "https?://(www\\.)?github\\.com",
            },
            {
              "pattern": "https?://raw\\.githubusercontent\\.com",
            },
            {
              "pattern": "https?://api\\.github\\.com",
            },
            {
              "pattern": "^https?://community\\.spotify\\.com",
            },
            {
              "pattern": "^https?://developer\\.spotify\\.com",
            },
            {
              "pattern": "^https?://developer\\.paddle\\.com",
            },
          ],
        },
        "create_directory": {
          "default": "allow",
        },
        "create_file": {
          "default": "allow",
          "always_allow": [{ "pattern": ".*" }],
        },
      },
    },

    "thread_summary_model": {
      "model": "claude-sonnet-4.6",
      "provider": "copilot_chat",
    },
  },
  "show_edit_predictions": true,

  "languages": {
    "Python": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"],
        },
      },
    },
    "JavaScript": {
      "format_on_save": "on",
      // "formatter": {
      //   "external": {
      //     "command": "prettier",
      //     "arguments": ["--stdin-filepath", "{buffer_path}"],
      //   },
      // },
    },
    "TypeScript": {
      "format_on_save": "on",
      // "formatter": {
      //   "external": {
      //     "command": "prettier",
      //     "arguments": ["--stdin-filepath", "{buffer_path}"],
      //   },
      // },
    },
    "CSS": {
      "language_servers": ["vscode-css-language-server"],

      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
  },
  "lsp": {
    "eslint": {
      "settings": {},
    },
    "basedpyright": {
      "settings": {
        "python.analysis": {
          "typeCheckingMode": "standard",
          "extraPaths": [
            "/Users/matemagyar/code/controlplane-be",
            "/Users/matemagyar/code/controlplane-be/local",
            "/Users/matemagyar/code/controlplane-be/local/.venv/lib/python3.12/site-packages",
          ],
          "useLibraryCodeForTypes": true,
          "ignoreMissingImports": true,
          "ignoreMissingTypeStubs": true,
          "autoSearchPaths": true,
          "openFilesOnly": false,
        },
        "python": {
          "pythonPath": "/Users/matemagyar/code/controlplane-be/local/.venv/bin/python",
          "venvPath": "/Users/matemagyar/code/controlplane-be/local/.venv",
        },
      },
    },
    "vtsls": {
      "settings": {
        "js/ts.implicitProjectConfig.checkJs": true,
        "javascript.validate.templateStringLiterals.identifiers": ["js", "html", "sql", "graphql"],
        "typescript.validate.templateStringLiterals.identifiers": ["js", "html", "sql", "graphql"],
        // "typescript.tsserver.experimental.enableProjectDiagnostics": true,
        // For JavaScript:
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "validate": {
            "templateStringLiterals": true,
          },
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": true,
            },
            "parameterTypes": { "enabled": true },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": { "enabled": true },
            "functionLikeReturnTypes": { "enabled": true },
            "enumMemberValues": { "enabled": true },
          },
        },
        // For TypeScript:
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "validate": {
            "templateStringLiterals": true,
          },
          "languageFeatures": {
            "semanticTokens": true,
          },
          "tsserver": { "experimental": { "enableProjectDiagnostics": true } },
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": true,
            },
            "parameterTypes": { "enabled": true },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": { "enabled": true },
            "functionLikeReturnTypes": { "enabled": true },
            "enumMemberValues": { "enabled": true },
          },
        },
      },
    },
  },
}
