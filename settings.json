// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "tabs": { "file_icons": true },

  "max_tabs": 5,
  "colorize_brackets": true,
  "indent_guides": {
    "background_coloring": "disabled",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Catppuccin Macchiato",
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Macchiato",
  },
  "jupyter": {
    "enabled": true,
    "kernel_selections": {
      "python": "conda-env",
      "typescript": "deno",
      "javascript": "deno",
      "r": "ark",
  "language_models": {
    "openai_compatible": {
      "mlx-lm": {
        "api_url": "http://localhost:19999",
        "available_models": [
          {
            "name": "lmstudio-community/Qwen3-Coder-30B-A3B-Instruct-MLX-6bit",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
    "ollama": {
      "api_url": "http://localhost:11434",
    },
  },
  "theme": "Ayu Dark",
  "jupyter": {},
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "mode": "eager",
    "enabled_in_text_threads": true,
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^mkdir\\b"
            },
            {
              "pattern": "^ls\\s+slx/bun/node_modules(\\s|$)"
            },
            {
              "pattern": "^ls\\b"
            },
            {
              "pattern": "^ls\\s+node_modules/@types(\\s|$)"
            },
            {
              "pattern": "^bun\\s+run(\\s|$)"
            },
            {
              "pattern": "^cd\\s+bun(\\s|$)"
            },
            {
              "pattern": "^cat\\s+bun/node_modules/@types/uuid/package\\.json(\\s|$)"
            },
            {
              "pattern": "^find\\s+bun/src(\\s|$)"
            },
            {
              "pattern": "^cd\\s+/Users/matemagyar/slx/bun(\\s|$)"
            },
            {
              "pattern": "^pkill\\b"
            },
            {
              "pattern": "^sleep\\s+3(\\s|$)"
            },
            {
              "pattern": "^curl\\b"
            },
            {
              "pattern": "^grep\\b"
            }
          ],
        },
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://raw\\.githubusercontent\\.com"
            },
            {
              "pattern": "^https?://v4\\.zod\\.dev"
            }
          ],
        },
      },
    },
    "default_profile": "write",
    "default_model": {
      "provider": "google",
      "model": "gemini-3-pro-preview",
    "thread_summary_model": {
      "model": "claude-sonnet-4.6",
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
    },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
  },
  // "show_completions_on_input": false,
  "show_edit_predictions": true,
  "vim_mode": true,
  "ui_font_size": 14.0,
  "buffer_font_size": 14.0,
  "soft_wrap": "editor_width",
  "autosave": "on_focus_change",
  "auto_signature_help": false,
  "show_signature_help_after_edits": false,
  "preferred_line_length": 100,
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": true,
    "toggle_on_modifiers_press": {
      "function": true,
    },
  },
  "buffer_font_features": { "calt": false },
  "use_autoclose": false,
  "terminal": {
    "font_size": 14.0,
    "dock": "bottom",
    "detect_venv": {
      "on": {
        // Default directories to search for virtual environments, relative
        // to the current working directory. We recommend overriding this
        // in your project's settings, rather than globally.
        "directories": [".venv", "venv", "local/.venv"],
        // Can also be `csh`, `fish`, and `nushell`
        "activate_script": "default",
      },
    },
  },
  "languages": {
    "CSS": {
      "language_servers": ["vscode-css-language-server"],

      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "TOML": {
      "format_on_save": "off",
    },
  },
  "lsp": {
    "eslint": {
      "settings": {},
    },
    "css": {
      "templateStringLanguages": ["css", "styled"],
      "embeddedLanguages": {
        "css": ["javascript", "typescript", "javascriptreact", "typescriptreact"],
      },
    },
    "basedpyright": {
      "settings": {
        "python.analysis": {
          "typeCheckingMode": "standard",
          "extraPaths": [
            "/Users/matemagyar/code/controlplane-be",
            "/Users/matemagyar/code/controlplane-be/local",
            "/Users/matemagyar/code/controlplane-be/local/.venv/lib/python3.12/site-packages",
          ],
          "useLibraryCodeForTypes": true,
          "ignoreMissingImports": true,
          "ignoreMissingTypeStubs": true,
          "autoSearchPaths": true,
          // "diagnosticMode": "",
          "openFilesOnly": false,
        },
        "python": {
          "pythonPath": "/Users/matemagyar/code/controlplane-be/local/.venv/bin/python",
          "venvPath": "/Users/matemagyar/code/controlplane-be/local/.venv",
        },
      },
    },
    "vtsls": {
      "settings": {
        "js/ts.implicitProjectConfig.checkJs": true,
        "javascript.validate.templateStringLiterals.identifiers": ["js", "html", "sql", "graphql"],
        "typescript.validate.templateStringLiterals.identifiers": ["js", "html", "sql", "graphql"],
        // "typescript.tsserver.experimental.enableProjectDiagnostics": true,
        // For JavaScript:
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "validate": {
            "templateStringLiterals": true,
          },
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": true,
            },
            "parameterTypes": { "enabled": true },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": { "enabled": true },
            "functionLikeReturnTypes": { "enabled": true },
            "enumMemberValues": { "enabled": true },
          },
        },
        // For TypeScript:
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "validate": {
            "templateStringLiterals": true,
          },
          "languageFeatures": {
            "semanticTokens": true,
          },
          "tsserver": { "experimental": { "enableProjectDiagnostics": true } },
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": true,
            },
            "parameterTypes": { "enabled": true },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": { "enabled": true },
            "functionLikeReturnTypes": { "enabled": true },
            "enumMemberValues": { "enabled": true },
          },
        },
      },
    },
  },
}
